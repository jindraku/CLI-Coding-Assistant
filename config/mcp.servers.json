{
  "servers": [
    {
      "name": "filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/"],
      "env": {}
    },
    {
      "name": "context7",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "SET_ME"
      },
      "enabled": true,
      "requiredEnv": ["CONTEXT7_API_KEY"]
    },
    {
      "name": "rag",
      "command": "npx",
      "args": ["-y", "tsx", "servers/rag-server/src/index.ts"],
      "env": {}
    }
  ]
}
